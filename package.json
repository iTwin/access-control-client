{
  "name": "@itwin/access-control-client",
  "version": "4.1.0",
  "description": "Access control client for the iTwin platform",
  "main": "lib/cjs/access-control-client.js",
  "module": "lib/esm/access-control-client.js",
  "typings": "lib/cjs/access-control-client",
  "files": [
    "lib",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./lib/esm/access-control-client.d.ts",
        "default": "./lib/esm/access-control-client.js"
      },
      "require": {
        "types": "./lib/cjs/access-control-client.d.ts",
        "default": "./lib/cjs/access-control-client.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run -s build:cjs && pnpm run -s build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "clean": "rimraf lib",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "check": "changeset status",
    "lint": "eslint -f visualstudio \"./src/**/*.ts\" 1>&2",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@changesets/cli": "^2.3.0",
    "@changesets/types": "6.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@itwin/build-tools": "^5.7.2",
    "@itwin/core-bentley": "^5.7.2",
    "@itwin/eslint-plugin": "^6.0.0",
    "@itwin/oidc-signin-tool": "^5.1.1",
    "@playwright/test": "1.56.0",
    "@types/node": "25.5.00",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.3.0",
    "dotenv-expand": "^12.0.3",
    "eslint": "^9.39.4",
    "rimraf": "^6.1.3",
    "source-map-loader": "^5.0.0",
    "typedoc": "^0.28.17",
    "typescript": "~5.9.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iTwin/access-control-client"
  },
  "author": {
    "name": "Bentley Systems, Inc",
    "url": "http://www.bentley.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "Bentley",
    "iTwin",
    "access-control"
  ],
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "diff": ">=8.0.3",
      "esbuild": ">=0.25.0"
    }
  }
}
